#!/usr/bin/env sh

#
# for this to work you must configure sudo such that
# it will be able to run the command without password
#
# see this wiki page for information:
#  - https://github.com/koekeishiya/yabai/wiki/Installing-yabai-(latest-release)#configure-scripting-addition

# Load theme configuration
source "${HOME}/.config/theme/colors.sh"

yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
sudo yabai --load-sa

# Ensure exactly 10 labeled spaces (handles extra/unlabeled spaces from macOS)
# This prevents workspace migration issues on yabai restart
$HOME/.config/yabai/helpers/ensure_spaces.sh

# global settings
yabai -m config \
	menubar_opacity 1.0 \
	mouse_follows_focus on \
	focus_follows_mouse off \
	display_arrangement_order default \
	window_origin_display default \
	window_placement second_child \
	window_insertion_point focused \
	window_zoom_persist on \
	window_shadow on \
	window_animation_duration 0.1 \
	window_animation_easing ease_out_circ \
	window_opacity_duration 0.1 \
	active_window_opacity 1.0 \
	normal_window_opacity 0.90 \
	window_opacity on \
	insert_feedback_color $THEME_INSERT_FEEDBACK \
	split_ratio 0.50 \
	split_type auto \
	auto_balance off \
	bottom_padding 12 \
	left_padding 12 \
	right_padding 12 \
	window_gap 12 \
	layout bsp \
	mouse_modifier fn \
	mouse_action1 move \
	mouse_action2 resize \
	mouse_drop_action swap

# Disable macOS Mission Control space rearranging
# This is critical to prevent workspace shuffling
yabai -m config auto_balance off

# Per-display top padding using external_bar (mimics AeroSpace per-monitor padding)
# Display 1 (1800x1169): Built-in MacBook - 20px top padding
# Display 2 (1920x1080): Samsung external - 55px top padding
yabai -m config --display 1 external_bar all:20:0
yabai -m config --display 2 external_bar all:55:0

# Load window rules for floating windows (matching AeroSpace config)
source "${HOME}/.config/yabai/rules.sh"

# Integrate with Sketchybar (signals)
# Pass workspace label instead of ID by querying the space
yabai -m signal --add event=space_changed action="sketchybar --trigger yabai_space_change FOCUSED_WORKSPACE=\$(yabai -m query --spaces --space | jq -r '.label')"
yabai -m signal --add event=window_focused action="sketchybar --trigger yabai_focus_change FOCUSED_WORKSPACE=\$(yabai -m query --spaces --space | jq -r '.label')"
yabai -m signal --add event=window_created action="sketchybar --trigger yabai_window_change"
yabai -m signal --add event=window_destroyed action="sketchybar --trigger yabai_window_change"
yabai -m signal --add event=window_minimized action="sketchybar --trigger yabai_window_change"
yabai -m signal --add event=window_deminimized action="sketchybar --trigger yabai_window_change"
yabai -m signal --add event=application_front_switched action="sketchybar --trigger front_app_switched"

# Display change event handlers - prevent workspace reshuffling
yabai -m signal --add event=display_added action="$HOME/.config/yabai/helpers/handle_display_change.sh"
yabai -m signal --add event=display_removed action="$HOME/.config/yabai/helpers/handle_display_change.sh"
yabai -m signal --add event=display_changed action="$HOME/.config/yabai/helpers/handle_display_change.sh"
yabai -m signal --add event=display_moved action="$HOME/.config/yabai/helpers/handle_display_change.sh"

echo "yabai configuration loaded.."
